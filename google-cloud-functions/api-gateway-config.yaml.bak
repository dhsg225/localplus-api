      responses:
        '200': { description: Success }
    options:
      operationId: optionsAuth
      security:
        - api_key: []
      x-google-backend:
        address: https://us-central1-marketing-saas-ai.cloudfunctions.net/localplus-api-auth
      responses:
        '200': { description: Success }

