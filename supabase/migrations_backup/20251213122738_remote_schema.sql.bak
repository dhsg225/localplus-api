COMMENT ON TABLE "public"."event_types" IS 'Hierarchical event taxonomy: categories (level 1), sub-categories (level 2), sub-sub-categories (level 3)';



COMMENT ON COLUMN "public"."event_types"."parent_id" IS 'Parent category ID for hierarchy';



COMMENT ON COLUMN "public"."event_types"."level" IS 'Taxonomy level: 1=category, 2=sub-category, 3=sub-sub-category';



CREATE OR REPLACE VIEW "public"."event_types_hierarchy" AS
 SELECT "et"."id",
    "et"."key",
    "et"."label",
    "et"."description",
    "et"."color",
    "et"."icon",
    "et"."level",
    "et"."parent_id",
    "et"."sort_order",
    "et"."is_active",
    "et"."created_at",
    "et"."updated_at",
    "public"."get_event_type_path"("et"."id") AS "full_path",
    "parent"."label" AS "parent_label",
    "parent"."key" AS "parent_key"
   FROM ("public"."event_types" "et"
     LEFT JOIN "public"."event_types" "parent" ON (("et"."parent_id" = "parent"."id")))
  WHERE ("et"."is_active" = true)
  ORDER BY "et"."level", "et"."sort_order", "et"."label";


ALTER VIEW "public"."event_types_hierarchy" OWNER TO "postgres";


