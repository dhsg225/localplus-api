CREATE OR REPLACE VIEW "public"."notification_analytics" AS
 SELECT "date"("sent_at") AS "date",
    "type",
    "provider",
    "success",
    "count"(*) AS "total_sent",
    "count"(
        CASE
            WHEN ("success" = true) THEN 1
            ELSE NULL::integer
        END) AS "successful",
    "count"(
        CASE
            WHEN ("success" = false) THEN 1
            ELSE NULL::integer
        END) AS "failed",
    "round"(((("count"(
        CASE
            WHEN ("success" = true) THEN 1
            ELSE NULL::integer
        END))::numeric * 100.0) / ("count"(*))::numeric), 2) AS "success_rate"
   FROM "public"."notification_logs"
  WHERE ("sent_at" >= ("now"() - '30 days'::interval))
  GROUP BY ("date"("sent_at")), "type", "provider", "success"
  ORDER BY ("date"("sent_at")) DESC, "type", "provider";


ALTER VIEW "public"."notification_analytics" OWNER TO "postgres";


