CREATE OR REPLACE VIEW "public"."business_locations" AS
 SELECT "b"."id",
    "b"."name",
    "b"."address_line",
    "b"."postal_code",
    "b"."address" AS "original_address",
    "b"."partnership_status",
    "b"."latitude",
    "b"."longitude",
    "p"."name_en" AS "province_name",
    "p"."name_th" AS "province_name_th",
    "d"."name_en" AS "district_name",
    "d"."name_th" AS "district_name_th",
    "s"."name_en" AS "sub_district_name",
    "s"."name_th" AS "sub_district_name_th",
    "concat_ws"(', '::"text", COALESCE("b"."address_line", ''::"text"), COALESCE("s"."name_en", ''::character varying), COALESCE("d"."name_en", ''::character varying), COALESCE("p"."name_en", ''::character varying)) AS "full_address"
   FROM ((("public"."businesses" "b"
     LEFT JOIN "public"."provinces" "p" ON (("b"."province_id" = "p"."id")))
     LEFT JOIN "public"."districts" "d" ON (("b"."district_id" = "d"."id")))
     LEFT JOIN "public"."sub_districts" "s" ON (("b"."sub_district_id" = "s"."id")))
  WHERE (("b"."partnership_status")::"text" = 'active'::"text");


ALTER VIEW "public"."business_locations" OWNER TO "postgres";


