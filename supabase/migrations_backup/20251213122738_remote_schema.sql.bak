CREATE OR REPLACE VIEW "public"."business_types_with_menus" AS
 SELECT "bt"."id",
    "bt"."key",
    "bt"."name",
    "bt"."description",
    "bt"."icon",
    "bt"."color",
    "bt"."is_active",
    "bt"."sort_order",
    "json_agg"("json_build_object"('id', "mi"."id", 'key', "mi"."key", 'label', "mi"."label", 'icon', "mi"."icon", 'route', "mi"."route", 'description', "mi"."description", 'is_required', "btm"."is_required", 'sort_order', "btm"."sort_order") ORDER BY "btm"."sort_order", "mi"."sort_order") FILTER (WHERE ("mi"."id" IS NOT NULL)) AS "menus"
   FROM (("public"."business_types" "bt"
     LEFT JOIN "public"."business_type_menus" "btm" ON (("btm"."business_type_id" = "bt"."id")))
     LEFT JOIN "public"."menu_items" "mi" ON ((("mi"."id" = "btm"."menu_item_id") AND ("mi"."is_active" = true))))
  WHERE ("bt"."is_active" = true)
  GROUP BY "bt"."id", "bt"."key", "bt"."name", "bt"."description", "bt"."icon", "bt"."color", "bt"."is_active", "bt"."sort_order"
  ORDER BY "bt"."sort_order", "bt"."name";


ALTER VIEW "public"."business_types_with_menus" OWNER TO "postgres";


