CREATE OR REPLACE FUNCTION "public"."has_role"("user_uuid" "uuid", "role_name" "text") RETURNS boolean
    LANGUAGE "plpgsql" SECURITY DEFINER
    AS $$
BEGIN
  RETURN EXISTS (
    SELECT 1 
    FROM user_roles 
    WHERE user_id = user_uuid 
    AND role = role_name 
    AND is_active = true
  );
END;
$$;


ALTER FUNCTION "public"."has_role"("user_uuid" "uuid", "role_name" "text") OWNER TO "postgres";


CREATE OR REPLACE FUNCTION "public"."is_admin_or_superuser"("check_user_id" "uuid") RETURNS boolean
    LANGUAGE "plpgsql" SECURITY DEFINER
    AS $$
BEGIN
  RETURN EXISTS (
    SELECT 1 
    FROM user_roles 
    WHERE user_id = check_user_id 
    AND role IN ('admin', 'super_admin', 'events_superuser')
    AND is_active = true
  );
END;
$$;


ALTER FUNCTION "public"."is_admin_or_superuser"("check_user_id" "uuid") OWNER TO "postgres";


