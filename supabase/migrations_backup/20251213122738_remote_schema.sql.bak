    CONSTRAINT "provinces_region_check" CHECK ((("region")::"text" = ANY (ARRAY[('central'::character varying)::"text", ('northern'::character varying)::"text", ('northeastern'::character varying)::"text", ('southern'::character varying)::"text", ('eastern'::character varying)::"text", ('western'::character varying)::"text"])))
);


