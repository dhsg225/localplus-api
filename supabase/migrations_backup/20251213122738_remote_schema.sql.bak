    "sms_enabled" boolean DEFAULT false,
    "email_templates" "jsonb" DEFAULT '{"no_show": "Your booking at {{restaurant_name}} for {{date}} at {{time}} has been marked as no-show.", "reminder": "Reminder: Your booking at {{restaurant_name}} is tomorrow at {{time}} for {{party_size}} people. Confirmation code: {{confirmation_code}}", "cancellation": "Your booking at {{restaurant_name}} for {{date}} at {{time}} has been cancelled. {{cancellation_reason}}", "confirmation": "Your booking at {{restaurant_name}} has been confirmed for {{date}} at {{time}} for {{party_size}} people. Confirmation code: {{confirmation_code}}"}'::"jsonb",
    "sms_templates" "jsonb" DEFAULT '{"no_show": "Booking marked as no-show at {{restaurant_name}} for {{date}} at {{time}}.", "reminder": "Reminder: Booking tomorrow at {{time}} at {{restaurant_name}}. Code: {{confirmation_code}}", "cancellation": "Booking cancelled at {{restaurant_name}} for {{date}} at {{time}}.", "confirmation": "Booking confirmed at {{restaurant_name}} for {{date}} at {{time}}. Code: {{confirmation_code}}"}'::"jsonb",
    "reminder_hours_before" integer DEFAULT 24,
    "auto_send_confirmations" boolean DEFAULT true,
    "auto_send_reminders" boolean DEFAULT true,
    "created_at" timestamp with time zone DEFAULT "now"(),
    "updated_at" timestamp with time zone DEFAULT "now"(),
    CONSTRAINT "notification_preferences_reminder_hours_before_check" CHECK ((("reminder_hours_before" >= 1) AND ("reminder_hours_before" <= 168)))
);


