    "id" "uuid" DEFAULT "extensions"."uuid_generate_v4"() NOT NULL,
    "provider_name" character varying(50) NOT NULL,
    "provider_type" character varying(10),
    "config" "jsonb" NOT NULL,
    "is_enabled" boolean DEFAULT false,
    "created_at" timestamp with time zone DEFAULT "now"(),
    "updated_at" timestamp with time zone DEFAULT "now"(),
    CONSTRAINT "provider_configs_provider_type_check" CHECK ((("provider_type")::"text" = ANY ((ARRAY['email'::character varying, 'sms'::character varying])::"text"[])))
);


ALTER TABLE "public"."provider_configs" OWNER TO "postgres";


CREATE TABLE IF NOT EXISTS "public"."recurrence_rules" (
    "id" "uuid" DEFAULT "gen_random_uuid"() NOT NULL,
    "event_id" "uuid" NOT NULL,
    "frequency" character varying(20) NOT NULL,
    "interval" integer DEFAULT 1 NOT NULL,
    "byweekday" integer[],
    "bymonthday" integer,
    "bysetpos" integer,
    "until" timestamp with time zone,
    "count" integer,
    "exceptions" "date"[] DEFAULT '{}'::"date"[],
    "additional_dates" "date"[] DEFAULT '{}'::"date"[],
    "timezone" "text" DEFAULT 'UTC'::"text" NOT NULL,
    "created_at" timestamp with time zone DEFAULT "now"(),
    "updated_at" timestamp with time zone DEFAULT "now"(),
    CONSTRAINT "recurrence_rules_bymonthday_check" CHECK ((("bymonthday" IS NULL) OR (("bymonthday" >= 1) AND ("bymonthday" <= 31)))),
    CONSTRAINT "recurrence_rules_bysetpos_check" CHECK ((("bysetpos" IS NULL) OR (("bysetpos" >= '-1'::integer) AND ("bysetpos" <= 4)))),
    CONSTRAINT "recurrence_rules_count_check" CHECK ((("count" IS NULL) OR ("count" > 0))),
    CONSTRAINT "recurrence_rules_frequency_check" CHECK ((("frequency")::"text" = ANY ((ARRAY['daily'::character varying, 'weekly'::character varying, 'monthly'::character varying, 'yearly'::character varying])::"text"[]))),
    CONSTRAINT "recurrence_rules_interval_check" CHECK (("interval" > 0)),
    CONSTRAINT "valid_end_condition" CHECK ((("until" IS NULL) OR ("count" IS NULL))),
    CONSTRAINT "valid_monthly_rule" CHECK (((("frequency")::"text" <> 'monthly'::"text") OR ("bymonthday" IS NOT NULL) OR (("bysetpos" IS NOT NULL) AND ("byweekday" IS NOT NULL)))),
    CONSTRAINT "valid_weekly_rule" CHECK (((("frequency")::"text" <> 'weekly'::"text") OR ("byweekday" IS NOT NULL)))
);


ALTER TABLE "public"."recurrence_rules" OWNER TO "postgres";


CREATE TABLE IF NOT EXISTS "public"."restaurant_settings" (
    "id" "uuid" DEFAULT "extensions"."uuid_generate_v4"() NOT NULL,
    "business_id" "uuid",
    "booking_enabled" boolean DEFAULT true,
    "advance_booking_days" integer DEFAULT 30,
    "max_party_size" integer DEFAULT 12,
    "min_party_size" integer DEFAULT 1,
    "booking_buffer_minutes" integer DEFAULT 15,
    "cancellation_policy" "text" DEFAULT 'Free cancellation up to 2 hours before booking time'::"text",
    "special_instructions" "text",
    "auto_confirm" boolean DEFAULT false,
    "require_phone" boolean DEFAULT true,
    "require_email" boolean DEFAULT true,
    "created_at" timestamp with time zone DEFAULT "now"(),
    "updated_at" timestamp with time zone DEFAULT "now"(),
    CONSTRAINT "restaurant_settings_advance_booking_days_check" CHECK (("advance_booking_days" > 0)),
    CONSTRAINT "restaurant_settings_booking_buffer_minutes_check" CHECK (("booking_buffer_minutes" >= 0)),
    CONSTRAINT "restaurant_settings_max_party_size_check" CHECK (("max_party_size" > 0)),
    CONSTRAINT "restaurant_settings_min_party_size_check" CHECK (("min_party_size" > 0))
);


ALTER TABLE "public"."restaurant_settings" OWNER TO "postgres";


CREATE TABLE IF NOT EXISTS "public"."sales_leads" (
    "id" "uuid" DEFAULT "extensions"."uuid_generate_v4"() NOT NULL,
    "business_id" "uuid",
    "suggested_business_id" "uuid",
    "lead_source" character varying(50) DEFAULT 'curation_pipeline'::character varying,
    "priority_level" integer DEFAULT 3,
    "estimated_partnership_value" numeric(10,2),
    "outreach_status" character varying(30) DEFAULT 'new'::character varying,
    "assigned_to" character varying(255),
    "first_contact_date" "date",
    "last_contact_date" "date",
    "conversion_date" "date",
    "notes" "text",
    "contact_attempts" integer DEFAULT 0,
    "partnership_tier" character varying(20),
    "created_at" timestamp with time zone DEFAULT "now"(),
    "updated_at" timestamp with time zone DEFAULT "now"(),
    CONSTRAINT "sales_leads_outreach_status_check" CHECK ((("outreach_status")::"text" = ANY (ARRAY[('new'::character varying)::"text", ('contacted'::character varying)::"text", ('interested'::character varying)::"text", ('negotiating'::character varying)::"text", ('converted'::character varying)::"text", ('declined'::character varying)::"text", ('inactive'::character varying)::"text"]))),
    CONSTRAINT "sales_leads_priority_level_check" CHECK ((("priority_level" >= 1) AND ("priority_level" <= 5)))
);


ALTER TABLE "public"."sales_leads" OWNER TO "postgres";


CREATE TABLE IF NOT EXISTS "public"."stamp_transactions" (
    "id" "uuid" DEFAULT "gen_random_uuid"() NOT NULL,
